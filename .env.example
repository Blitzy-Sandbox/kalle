# Database
DATABASE_URL=postgresql://kalle:kalle_secret@localhost:5432/kalle?schema=public

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=your-jwt-secret-change-in-production
JWT_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Server
PORT=3001
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_WS_URL=http://localhost:3001

# Storage
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=26214400

# Logging
LOG_LEVEL=debug

# OpenTelemetry
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=kalle-api

# Backup
BACKUP_DIR=./backups
BACKUP_RETENTION_DAYS=7
PGHOST=localhost
PGPORT=5432
PGUSER=kalle
PGPASSWORD=kalle_secret
PGDATABASE=kalle
