# =============================================================================
# Kalle — WhatsApp Clone · Environment Variables
# =============================================================================
#
# USAGE:
#   cp .env.example .env
#   docker compose up
#
# All defaults below are configured for local Docker development.
# No external services, cloud accounts, or API keys required (Rule R38).
#
# WARNING: Never commit .env to version control — it is listed in .gitignore.
#
# PRODUCTION NOTES:
#   Variables marked [CHANGE IN PRODUCTION] MUST be replaced with secure,
#   randomly generated values before any non-local deployment.
#
# =============================================================================

# -----------------------------------------------------------------------------
# PostgreSQL — Docker Compose Service Variables
# -----------------------------------------------------------------------------
# These variables are read by docker-compose.yml to configure the postgres
# service container. They are also used to construct DATABASE_URL dynamically
# inside the api, worker, and backup service containers.
# -----------------------------------------------------------------------------
PGUSER=kalle
PGPASSWORD=kalle_dev_password
PGDATABASE=kalle_db
PGPORT=5432
PGHOST=postgres

# -----------------------------------------------------------------------------
# PostgreSQL — Non-Superuser Application Role (Rule R32)
# -----------------------------------------------------------------------------
# The API and worker services connect as a NON-SUPERUSER role so that
# REVOKE UPDATE, DELETE on audit_logs is enforced by PostgreSQL.
# This role is created automatically by scripts/init-db.sh on first boot.
# [CHANGE IN PRODUCTION] — use a strong, randomly generated password.
# -----------------------------------------------------------------------------
APP_DB_USER=kalle_app
APP_DB_PASSWORD=kalle_app_password

# -----------------------------------------------------------------------------
# Database — Application Connection String
# -----------------------------------------------------------------------------
# Used by the API server and worker to connect to PostgreSQL via Prisma ORM.
# Uses the non-superuser kalle_app role for R32 audit log immutability.
# In Docker, the hostname "postgres" resolves to the postgres service container.
# For non-Docker local development, change "postgres" to "localhost".
# [CHANGE IN PRODUCTION] — use a secure password and production hostname.
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://kalle_app:kalle_app_password@postgres:5432/kalle_db?schema=public

# -----------------------------------------------------------------------------
# Database — Migration Connection String (Superuser)
# -----------------------------------------------------------------------------
# Used only for running Prisma migrations and applying post-migration SQL
# grants. Requires DDL privileges (CREATE TABLE, ALTER, etc.) that the
# application role does not have. Never used for runtime application queries.
# [CHANGE IN PRODUCTION] — restrict access to this credential.
# -----------------------------------------------------------------------------
MIGRATION_DATABASE_URL=postgresql://kalle:kalle_dev_password@postgres:5432/kalle_db?schema=public

# -----------------------------------------------------------------------------
# Redis — Cache, Pub/Sub, Session Store, BullMQ Broker
# -----------------------------------------------------------------------------
# Used by the API server for caching (presence, token blacklist), Socket.IO
# Redis adapter for horizontal scaling, and BullMQ job queue broker.
# In Docker, the hostname "redis" resolves to the redis service container.
# For non-Docker local development, change "redis" to "localhost".
# -----------------------------------------------------------------------------
REDIS_URL=redis://redis:6379

# -----------------------------------------------------------------------------
# BullMQ — Job Queue Redis Connection
# -----------------------------------------------------------------------------
# Optional separate Redis URL for BullMQ. If not set, the API server and
# worker fall back to REDIS_URL. Set this if you need a dedicated Redis
# instance for job processing in production.
# -----------------------------------------------------------------------------
BULL_REDIS_URL=redis://redis:6379

# -----------------------------------------------------------------------------
# JWT / Authentication
# -----------------------------------------------------------------------------
# JWT_SECRET: Signing key for access and refresh tokens. Must be at least
#   32 characters. [CHANGE IN PRODUCTION] — generate a cryptographically
#   random string (e.g., openssl rand -base64 48).
# JWT_ACCESS_TOKEN_EXPIRY: Access token lifetime (e.g., 15m, 1h).
# JWT_REFRESH_TOKEN_EXPIRY: Refresh token lifetime (e.g., 7d, 30d).
# -----------------------------------------------------------------------------
JWT_SECRET=kalle-local-dev-jwt-secret-change-in-production
JWT_ACCESS_TOKEN_EXPIRY=15m
JWT_REFRESH_TOKEN_EXPIRY=7d

# -----------------------------------------------------------------------------
# Server — Ports and Runtime
# -----------------------------------------------------------------------------
# PORT: Host-level port mapping used by docker-compose for the API service.
# API_PORT: The port the Express API server listens on inside the container.
#   These should match so Docker port mapping (PORT:API_PORT) works correctly.
# WEB_PORT: The port the Next.js frontend listens on (used by docker-compose).
# NODE_ENV: Runtime environment — development enables hot reload and debug logs.
# -----------------------------------------------------------------------------
PORT=3001
API_PORT=3001
WEB_PORT=3000
NODE_ENV=development

# -----------------------------------------------------------------------------
# CORS — Cross-Origin Resource Sharing
# -----------------------------------------------------------------------------
# Comma-separated list of allowed origins for API requests from the frontend.
# Must include the frontend URL (http://localhost:3000 for local Docker dev).
# The X-Correlation-ID header is exposed for request tracing (Rule R29).
# -----------------------------------------------------------------------------
CORS_ORIGIN=http://localhost:3000

# -----------------------------------------------------------------------------
# Frontend — Public Environment Variables
# -----------------------------------------------------------------------------
# NEXT_PUBLIC_* vars are inlined into the Next.js client bundle at build time.
# These point to the API server as accessed from the browser (localhost, not
# the Docker service hostname).
# -----------------------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_WS_URL=http://localhost:3001

# -----------------------------------------------------------------------------
# Storage — Encrypted Media File Uploads
# -----------------------------------------------------------------------------
# UPLOAD_DIR: Directory for encrypted media file storage. In Docker, this is
#   mounted as a named volume at /app/uploads. For local dev, ./uploads.
# MAX_FILE_SIZE: Maximum upload size in bytes. 26214400 = 25 * 1024 * 1024
#   = 25MB (Rule R8). Enforced both client-side and server-side.
# -----------------------------------------------------------------------------
UPLOAD_DIR=/app/uploads
MAX_FILE_SIZE=26214400

# -----------------------------------------------------------------------------
# Logging — Structured JSON Output
# -----------------------------------------------------------------------------
# Pino log level for backend services. All logs are structured JSON with
# correlation IDs (Rule R28, R29). Levels: fatal, error, warn, info, debug, trace.
# Use "debug" for development, "info" for production.
# -----------------------------------------------------------------------------
LOG_LEVEL=debug

# -----------------------------------------------------------------------------
# OpenTelemetry — Observability and Metrics
# -----------------------------------------------------------------------------
# OTEL_EXPORTER_OTLP_ENDPOINT: HTTP endpoint for the OpenTelemetry Collector.
#   The API uses OTLPMetricExporter (HTTP) to push metrics to the collector.
#   Port 4318 is the standard OTLP HTTP receiver port. In Docker,
#   "otel-collector" resolves to the collector service container.
# OTEL_SERVICE_NAME: Service identifier in traces and metrics (Rule R37).
# Metrics are exposed at /api/v1/metrics in Prometheus-compatible format.
# -----------------------------------------------------------------------------
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318
OTEL_SERVICE_NAME=kalle-api

# -----------------------------------------------------------------------------
# Backup — PostgreSQL Daily Backup Service (Rule R36)
# -----------------------------------------------------------------------------
# BACKUP_RETENTION_DAYS: Number of days to retain backup archives. Archives
#   older than this are automatically purged after each backup run.
# BACKUP_CRON: Cron expression for the daily backup schedule (default: 2 AM).
# BACKUP_DIR: Directory where pg_dump archives are stored. Mounted as a host
#   volume at ./backups in docker-compose.yml.
# -----------------------------------------------------------------------------
BACKUP_RETENTION_DAYS=7
BACKUP_CRON=0 2 * * *
BACKUP_DIR=/backups

# -----------------------------------------------------------------------------
# Database Seeding — First-Boot Data Population (Rule R39)
# -----------------------------------------------------------------------------
# SEED_ON_INIT: When set to "true", the API service runs `npx prisma db seed`
#   on startup to populate the database with deterministic test data (Rule R10).
#   The seed script is idempotent — running it multiple times produces identical
#   state, so it is safe to leave enabled across container restarts.
#
# Per Rule R39: "Developer clones repo and runs cp .env.example .env &&
#   docker-compose up. Migrations run automatically. Seed populates on first
#   boot." This variable must default to "true" in .env.example.
#
# Set to "false" to skip seeding (e.g., when connecting to a production DB).
# -----------------------------------------------------------------------------
SEED_ON_INIT=true

# =============================================================================
# V2 OAuth/OIDC + Feature Flags Integration (AUTH_V2_ENABLED Killswitch)
# =============================================================================
#
# These variables wire Kalle's API and Web apps to the new @blitzy/auth and
# @blitzy/admin-ui workspace libraries via HTTP. They are read by:
#   - apps/api/src/middleware/auth.ts (flag-first dispatch to legacy vs V2)
#   - apps/api/src/server.ts          (initAuth + initFlags composition root)
#   - apps/api/src/routes/v1/auth.routes.ts (POST /api/v1/auth/logout under V2)
#   - apps/web/src/app/(auth)/login/page.tsx (PKCE redirect to Keycloak)
#   - apps/web/src/app/auth/callback/page.tsx (PKCE code exchange)
#   - apps/web/src/lib/api.ts         (401 silent-refresh interceptor)
#
# CRITICAL — RULE R3 (Flag Isolation):
#   With AUTH_V2_ENABLED=false, ZERO @blitzy/auth code executes. Kalle's
#   legacy JWT auth path is byte-identical to the previous behavior. The
#   pre-existing test suite (1,814 tests) MUST continue to pass.
#
# CRITICAL — RULE R4 (Flag Exclusivity):
#   Per request, EXACTLY ONE of legacy AuthService or @blitzy/auth's
#   createExpressMiddleware executes. The flag is the first synchronous
#   step in middleware/auth.ts.
#
# CRITICAL — RULE R8 (Secrets Containment):
#   AUTH_SIDECAR_SECRET and FLAGS_API_SECRET are EMPTY in this template.
#   Generate per-environment with: openssl rand -hex 32
#   Then populate ONLY in the local, gitignored .env file.
#
# CRITICAL — RULE R2 / RULE RF2 (DB Boundary):
#   AUTH_DB_URL and FLAGS_DB_URL MUST NOT appear in this file (or anywhere
#   in kalle/). Kalle accesses auth and flag state ONLY via HTTP endpoints:
#     POST ${AUTH_SERVICE_URL}/validate
#     GET  ${FLAGS_API_URL}/flags/:name
# =============================================================================

# -----------------------------------------------------------------------------
# Feature Flag Killswitch (FR-9, Rule R3, Rule RF3)
# -----------------------------------------------------------------------------
# AUTH_V2_ENABLED:
#   Final fallback value when the flags API is unreachable (Rule RF3 fail-open).
#   Read order in middleware/auth.ts: in-process cache → flags API → process.env.
#   Default `false` keeps the legacy JWT path active.
#
#   To activate V2 OAuth in local dev:
#     1. Start the V2 Docker services: docker compose up -d auth-db keycloak \
#        flags-db auth-sidecar admin-ui
#     2. Run: pnpm --filter @blitzy/admin-ui seed-flags
#     3. Toggle the flag in the flags admin UI at http://localhost:4002
#        (or set AUTH_V2_ENABLED=true here AND in the flags database).
# -----------------------------------------------------------------------------
AUTH_V2_ENABLED=false

# -----------------------------------------------------------------------------
# Keycloak — OIDC Identity Provider (FR-1, FR-8, FR-11)
# -----------------------------------------------------------------------------
# KEYCLOAK_BASE_URL:
#   Base URL of the Keycloak server (NO trailing slash).
#   In Docker, the hostname `keycloak` resolves to the keycloak container.
#   For browser-side PKCE redirect flows, this URL must ALSO be reachable
#   from the user's browser. In local dev, set to http://localhost:8080
#   when accessing Kalle from the browser; the api/worker container uses
#   the in-network http://keycloak:8080 transparently.
#
# KEYCLOAK_REALM:
#   Realm name imported by the keycloak service from
#   `packages/auth/keycloak/realm-export.json` at first boot. Default `blitzy`.
#
# KEYCLOAK_CLIENT_ID:
#   OIDC client used by Kalle Web (PKCE) and validated by `aud` claim
#   inspection in @blitzy/auth's createExpressMiddleware. Default `kalle-app`
#   (public client, S256 PKCE per FR-8).
#
# KEYCLOAK_JWKS_URI (QA F-CRITICAL-4):
#   Optional override for the JWKS endpoint URL. When unset, `initAuth()`
#   derives it from `${KEYCLOAK_BASE_URL}/realms/${KEYCLOAK_REALM}/protocol/openid-connect/certs`.
#   Set this in SPLIT-ENDPOINT deployments where kalle reaches Keycloak via
#   an INTERNAL Docker hostname for JWKS fetching while browsers reach
#   Keycloak via a PUBLIC URL. Example:
#   http://keycloak:8080/realms/blitzy/protocol/openid-connect/certs
#
# KEYCLOAK_ISSUER (QA F-CRITICAL-4):
#   Optional override for the expected JWT `iss` claim. When unset,
#   `initAuth()` derives it from `${KEYCLOAK_BASE_URL}/realms/${KEYCLOAK_REALM}`.
#   Set this in SPLIT-ENDPOINT deployments where Keycloak embeds the
#   BROWSER-perspective issuer URL in the `iss` claim of access tokens.
#   Kalle then validates the `iss` claim against this PUBLIC issuer even
#   though it fetches JWKS from the INTERNAL URL set by KEYCLOAK_JWKS_URI.
#   Example: http://localhost:8080/realms/blitzy
#   See `packages/auth/src/auth/types.ts` `AuthConfig.issuer` JSDoc.
# -----------------------------------------------------------------------------
KEYCLOAK_BASE_URL=http://keycloak:8080
KEYCLOAK_REALM=blitzy
KEYCLOAK_CLIENT_ID=kalle-app
# KEYCLOAK_JWKS_URI=
# KEYCLOAK_ISSUER=

# -----------------------------------------------------------------------------
# Auth Sidecar — @blitzy/auth Validation HTTP API (FR-2, Rule R2, Rule R13)
# -----------------------------------------------------------------------------
# AUTH_SERVICE_URL:
#   Base URL of the @blitzy/auth sidecar (NO trailing slash).
#   In Docker, the hostname `auth-sidecar` resolves to the sidecar container.
#   The sidecar exposes port 4001 with two endpoints:
#     POST /validate           (JWT signature → blacklist → audience → permission)
#     POST /backchannel-logout (Keycloak logout token → Redis SETEX blacklist)
#
#   When AUTH_V2_ENABLED=true, kalle's middleware/auth.ts calls this URL on
#   every protected request. Per Rule R13, sidecar failures fail-CLOSED:
#   the request returns HTTP 503 (no super()._authenticate() fallback).
#
# AUTH_SIDECAR_SECRET:
#   Bearer token required by the sidecar's /validate and /backchannel-logout
#   endpoints. EMPTY in this template per Rule R8. Generate per-environment:
#     openssl rand -hex 32
#   This SAME value MUST appear in:
#     - packages/auth/.env       (the sidecar's own validation key)
#     - packages/admin-ui/.env   (admin-ui calls /validate too)
#     - blitzy-odoo addon env    (Odoo calls /validate)
#   The keycloak server posts to /backchannel-logout WITHOUT this header
#   (it uses Keycloak's own logout-token signature for authentication).
# -----------------------------------------------------------------------------
AUTH_SERVICE_URL=http://auth-sidecar:4001
AUTH_SIDECAR_SECRET=

# -----------------------------------------------------------------------------
# Feature Flags API — @blitzy/admin-ui Evaluation HTTP API (FR-5, Rule RF3)
# -----------------------------------------------------------------------------
# FLAGS_API_URL:
#   Base URL of the @blitzy/admin-ui evaluation API (NO trailing slash).
#   In Docker, the hostname `admin-ui` resolves to the admin-ui container.
#   The evaluation API exposes port 4003 with one endpoint:
#     GET /flags/:name?subject=<email>  → { enabled, rollout_percentage }
#
#   Read by kalle's flag client to evaluate AUTH_V2_ENABLED. Per Rule RF3
#   (fail-OPEN), unreachable flags API falls back to process.env.AUTH_V2_ENABLED
#   above (NOT to HTTP 503).
#
# FLAGS_API_SECRET:
#   Bearer token required by the evaluation API. EMPTY per Rule R8.
#   Generate per-environment with: openssl rand -hex 32
#   Match this value in packages/admin-ui/.env exactly.
# -----------------------------------------------------------------------------
FLAGS_API_URL=http://admin-ui:4003
FLAGS_API_SECRET=

# -----------------------------------------------------------------------------
# Browser-Visible Keycloak Configuration — Kalle Web (FR-8 / F-CRITICAL-3)
# -----------------------------------------------------------------------------
# These NEXT_PUBLIC_* variables are baked into the kalle-web bundle and used
# by the Kalle Web login page (`apps/web/src/app/(auth)/login/page.tsx`) to
# construct the OAuth 2.0 authorization-endpoint URL when AUTH_V2_ENABLED=true.
#
# IMPORTANT: These URLs MUST be browser-perspective values (e.g. localhost:8080),
# NOT Docker network hostnames (e.g. keycloak:8080), because the user's browser
# is the entity that follows the authorization redirect — and the browser
# cannot resolve Docker network DNS aliases.
#
# In Docker Compose, these are set in the `web` service's `environment` block
# directly. In a non-Docker dev environment, they must be exported in your
# shell or set in a local `.env` file before `npm run dev`.
#
# The realm and client_id values match the canonical values in
# `packages/auth/keycloak/realm-export.json`.
# -----------------------------------------------------------------------------
NEXT_PUBLIC_KEYCLOAK_BASE_URL=http://localhost:8080
NEXT_PUBLIC_KEYCLOAK_REALM=blitzy
NEXT_PUBLIC_KEYCLOAK_CLIENT_ID=kalle-app

# =============================================================================
# End of V2 OAuth/OIDC + Feature Flags Integration
# =============================================================================
