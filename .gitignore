# ============================================================
# Kalle — WhatsApp Clone Monorepo .gitignore
# ============================================================
# Covers: Node.js, Build outputs, Environment, IDE, Testing,
#         Docker, Prisma, Backups, TypeScript, Turbo, Misc
# ============================================================

# -------------------------------------------------------
# Node.js — Dependencies and package manager artifacts
# -------------------------------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
.pnp
.pnp.js

# -------------------------------------------------------
# Build outputs — Compiled and bundled artifacts
# -------------------------------------------------------
dist/
build/
.next/
out/

# -------------------------------------------------------
# Environment files
# Keep .env.example in version control; ignore all .env files
# -------------------------------------------------------
.env
.env.local
.env.*.local

# -------------------------------------------------------
# IDE and editor files
# -------------------------------------------------------
.idea/
.vscode/
*.swp
*.swo
*~

# -------------------------------------------------------
# OS-generated files
# -------------------------------------------------------
.DS_Store
Thumbs.db

# -------------------------------------------------------
# Testing — Coverage reports and test output
# -------------------------------------------------------
coverage/
.nyc_output/
test-results/
playwright-report/

# -------------------------------------------------------
# Docker
# -------------------------------------------------------
.docker/


# -------------------------------------------------------
# Backups — Database backup archives
# -------------------------------------------------------
backups/*.gz
backups/*.sql

# -------------------------------------------------------
# Uploads — User-uploaded encrypted media files
# -------------------------------------------------------
uploads/

# -------------------------------------------------------
# TypeScript — Incremental build info
# -------------------------------------------------------
*.tsbuildinfo

# -------------------------------------------------------
# Turbo — Build cache
# -------------------------------------------------------
.turbo/

# -------------------------------------------------------
# Misc — Logs and temporary files
# -------------------------------------------------------
*.log
tmp/
temp/
