{
  "name": "@kalle/api",
  "version": "1.0.0",
  "private": true,
  "description": "WhatsApp clone Express backend with Socket.IO",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc --build",
    "dev": "nodemon",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit --strict",
    "lint": "eslint src/ --ext .ts --max-warnings 0",
    "lint:fix": "eslint src/ --ext .ts --fix",
    "test": "jest --coverage --passWithNoTests",
    "test:watch": "jest --watch",
    "test:integration": "jest --config jest.integration.config.ts --passWithNoTests",
    "clean": "rm -rf dist coverage .turbo"
  },
  "dependencies": {
    "@kalle/shared": "*",
    "@opentelemetry/api": "^1.8.0",
    "@opentelemetry/exporter-prometheus": "^0.51.0",
    "@opentelemetry/instrumentation-express": "^0.39.0",
    "@opentelemetry/instrumentation-http": "^0.51.0",
    "@opentelemetry/sdk-metrics": "^1.24.0",
    "@opentelemetry/sdk-node": "^0.51.0",
    "@prisma/client": "^5.14.0",
    "@socket.io/redis-adapter": "^8.3.0",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.7.0",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "express": "^4.19.0",
    "express-rate-limit": "^7.5.1",
    "helmet": "^7.1.0",
    "ioredis": "^5.4.0",
    "jsonwebtoken": "^9.0.0",
    "mime-types": "^2.1.35",
    "multer": "^1.4.5-lts.1",
    "open-graph-scraper": "^6.5.0",
    "pino": "^8.21.0",
    "pino-http": "^9.0.0",
    "socket.io": "^4.7.0",
    "uuid": "^9.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.0",
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.0",
    "@types/express": "^4.17.0",
    "@types/jest": "^29.5.0",
    "@types/jsonwebtoken": "^9.0.0",
    "@types/mime-types": "^2.1.4",
    "@types/multer": "^1.4.0",
    "@types/node": "^20.0.0",
    "@types/supertest": "^6.0.0",
    "@types/uuid": "^9.0.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.0",
    "supertest": "^6.3.0",
    "ts-jest": "^29.1.0",
    "tsx": "^4.11.0",
    "typescript": "^5.4.0"
  }
}
