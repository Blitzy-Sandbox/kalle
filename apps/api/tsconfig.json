{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "composite": true,
    "paths": {
      "@kalle/shared": ["../../packages/shared/src"],
      "@kalle/shared/*": ["../../packages/shared/src/*"]
    }
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "dist", "tests", "coverage"],
  "references": [
    { "path": "../../packages/shared" }
  ]
}
