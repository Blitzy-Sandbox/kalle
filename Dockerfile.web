# =============================================================================
# Dockerfile.web — Next.js 14 Frontend Multi-Stage Build (V2 / OAuth-aware)
# =============================================================================
# Production-grade multi-stage build for the Kalle WhatsApp clone frontend.
#
# F-CRITICAL-1 fix (QA Checkpoint F2): The build context is the REPOSITORY
# ROOT (one level above this Dockerfile). This change is required so the
# build can include both the kalle/ workspace AND the new sibling
# packages/auth and packages/admin-ui workspace libraries, which are referenced
# from kalle/apps/web/package.json via the
# `file:../../../packages/auth` protocol.
#
# Filesystem-Root Layout — see Dockerfile.api for full explanation.
# Summary:
#   /node_modules/.pnpm/...                        ← pnpm virtual store
#   /packages/auth/{dist,prisma,...}               ← built @blitzy/auth
#   /packages/admin-ui/{dist,prisma,...}           ← built @blitzy/admin-ui
#   /app/...                                        ← kalle workspace
#
# Build stages:
#   1. pnpm-deps — Install root pnpm workspace; build @blitzy/auth + @blitzy/admin-ui
#   2. deps      — Install kalle's npm workspace dependencies
#   3. builder   — Compile @kalle/shared + Next.js production build
#   4. runner    — Minimal Alpine image with standalone server
#
# Usage:
#   Production:  docker build -f kalle/Dockerfile.web -t kalle-web .
#   Dev mode:    docker compose up web  (overrides CMD with next dev)
#
# Requirements:
#   - Node.js 20 Alpine (matches monorepo engine requirement)
#   - pnpm 9.15.0 (root packages workspace)
#   - npm 11.1.0 (kalle workspace)
#   - Next.js standalone output mode (next.config.js: output: 'standalone')
#   - Non-root user for production security
#   - Port 3000 exposed
#   - NEXT_TELEMETRY_DISABLED=1 in both build and runtime
# =============================================================================

# -----------------------------------------------------------------------------
# Stage 1: pnpm-deps — Install + build @blitzy/auth and @blitzy/admin-ui
# -----------------------------------------------------------------------------
# This stage uses pnpm@9.15.0 (per repo-root packageManager) to install and
# build the two workspace libraries. The output is the pnpm node_modules tree
# (with relative symlinks into .pnpm) plus packages/{auth,admin-ui}/dist/.
#
# F-CRITICAL-1: Build context is the repo root. Source paths in COPY are
# therefore root-relative (e.g. `packages/auth/...` not `../packages/auth/...`).
# -----------------------------------------------------------------------------
FROM node:20-alpine AS pnpm-deps

# Alpine compatibility deps. openssl + libssl3 + libcrypto3 are needed so
# Prisma can generate the correct query/schema engine binaries against
# OpenSSL 3.x (Alpine 3.19+ default). These are required because @blitzy/auth
# and @blitzy/admin-ui both run prisma generate during build.
RUN apk add --no-cache libc6-compat openssl libssl3 libcrypto3 ca-certificates

# Pin pnpm to the version declared in repo-root package.json packageManager.
RUN corepack enable && corepack prepare pnpm@9.15.0 --activate

# Use a distinct WORKDIR for this stage so we don't accidentally collide
# with /app (kalle workspace) in subsequent stages.
WORKDIR /pnpm-workspace

# 1. Copy root pnpm workspace manifests FIRST for optimal layer caching.
COPY package.json pnpm-workspace.yaml pnpm-lock.yaml ./

# 2. Copy each package's package.json so pnpm-lock.yaml resolves correctly.
COPY packages/auth/package.json     ./packages/auth/
COPY packages/admin-ui/package.json ./packages/admin-ui/

# 3. Install ALL workspace deps deterministically (incl. devDependencies for build).
RUN pnpm install --frozen-lockfile --prefer-offline

# 4. Copy package source for both libraries.
COPY packages/auth     ./packages/auth/
COPY packages/admin-ui ./packages/admin-ui/

# 5. Generate Prisma clients (each package has its own schema).
RUN cd packages/auth     && pnpm exec prisma generate --schema prisma/schema.prisma
RUN cd packages/admin-ui && pnpm exec prisma generate --schema prisma/schema.prisma

# 6. Build both packages.
RUN pnpm --filter @blitzy/auth     build
RUN pnpm --filter @blitzy/admin-ui build

# -----------------------------------------------------------------------------
# Stage 2: deps — Install kalle npm workspace + carry pnpm artifacts forward
# -----------------------------------------------------------------------------
# This stage installs only the dependencies needed for the web frontend and
# the shared types package. By copying only package.json files first, Docker
# can cache this layer and skip reinstallation when only source code changes.
# -----------------------------------------------------------------------------
FROM node:20-alpine AS deps

# Alpine compatibility: libc6-compat is required by some npm native modules
# that expect glibc. This prevents runtime segfaults from missing shared libs.
RUN apk add --no-cache libc6-compat

WORKDIR /app

# F-CRITICAL-1: Place the built workspace packages and the pnpm virtual store
# at FILESYSTEM ROOT (not under /app), mirroring the host repo layout. The
# pnpm-internal relative symlinks (../../../node_modules/.pnpm/...) and
# kalle's npm-internal symlinks (created in the next step) both resolve into
# this layout via Node's standard upward node_modules walk.
#
# Note: kalle's npm ci will create /app/node_modules/@blitzy/auth as a relative
# symlink with target ../../../packages/auth → /packages/auth. ✓
COPY --from=pnpm-deps /pnpm-workspace/node_modules        /node_modules
COPY --from=pnpm-deps /pnpm-workspace/packages/auth       /packages/auth
COPY --from=pnpm-deps /pnpm-workspace/packages/admin-ui   /packages/admin-ui

# Copy root workspace manifests first for optimal Docker layer caching.
# Only changes to package.json or package-lock.json will invalidate this cache.
# Source paths are kalle/-prefixed because build context is the repo root.
COPY kalle/package.json kalle/package-lock.json ./

# Copy ALL workspace package manifests needed for dependency resolution.
# npm workspaces require all referenced workspace package.json files to be
# present for the lockfile resolution to succeed.
# Even though we only build apps/web here, npm ci will fail if any workspace
# manifest is missing because the lockfile contains entries for ALL workspaces.
COPY kalle/packages/shared/package.json ./packages/shared/
COPY kalle/apps/api/package.json ./apps/api/
COPY kalle/apps/web/package.json ./apps/web/
COPY kalle/workers/queue/package.json ./workers/queue/

# Copy Prisma schema BEFORE npm ci — the root package.json "prepare" script
# runs "npx prisma generate" during install, which requires the schema file.
# Without this, npm ci fails with "prisma/schema.prisma not found".
COPY kalle/prisma/ ./prisma/

# Install ALL dependencies from the lockfile.
# At this point npm will create /app/node_modules/@blitzy/auth as a symlink
# whose target resolves to /packages/auth (file:// reference in
# apps/web/package.json). Symlink resolves via the filesystem-root layout
# established above. ✓
RUN npm ci --legacy-peer-deps --ignore-scripts

# Explicitly generate Prisma client using the version installed in node_modules
# (^5.14.x per package.json), NOT the latest from the npm registry.
RUN npx prisma generate

# -----------------------------------------------------------------------------
# Stage 3: Builder — Compile shared types and Next.js application
# -----------------------------------------------------------------------------
# Builds the @kalle/shared TypeScript package first (dependency), then runs
# the Next.js production build which generates the standalone output bundle.
# -----------------------------------------------------------------------------
FROM node:20-alpine AS builder

WORKDIR /app

# Disable Next.js anonymous telemetry during build
ENV NEXT_TELEMETRY_DISABLED=1

# F-CRITICAL-1: Carry the filesystem-root @blitzy packages and pnpm store
# forward into the builder stage. They are required at build time because
# kalle apps/web source imports types from @blitzy/auth.
COPY --from=deps /node_modules /node_modules
COPY --from=deps /packages     /packages

# Copy installed node_modules from deps stage.
# npm ci without --workspace hoists ALL dependencies to the root node_modules.
# Workspace-specific node_modules are not created in this configuration.
COPY --from=deps /app/node_modules ./node_modules

# Copy root workspace configuration files needed for build resolution
COPY kalle/package.json ./
COPY kalle/tsconfig.base.json ./

# Copy shared package source — must be built before web since web imports from it
COPY kalle/packages/shared/ ./packages/shared/

# Copy web application source (pages, components, styles, assets, configs)
COPY kalle/apps/web/ ./apps/web/

# Build the shared types package first (@kalle/shared).
# This generates dist/ with compiled .js and .d.ts files that the web app
# imports via the workspace dependency link.
RUN npm run build --workspace=packages/shared

# Ensure public directory exists (may be empty in early development).
# This prevents COPY failures in the runner stage when public/ has no content yet.
RUN mkdir -p /app/apps/web/public

# Build the Next.js application in production mode.
# With output: 'standalone' in next.config.js, this generates a self-contained
# server at .next/standalone/ that includes only the files needed for production,
# plus a minimal Node.js server (server.js) that replaces `next start`.
# Static assets (.next/static) and public/ are NOT included in standalone
# and must be copied separately to the runner stage.
RUN npm run build --workspace=apps/web

# -----------------------------------------------------------------------------
# Stage 4: Runner — Minimal production image
# -----------------------------------------------------------------------------
# Uses a clean Alpine Node.js image with only the standalone build output.
# No source code, no devDependencies, no build tools — minimal attack surface.
# Runs as non-root user for security hardening.
# -----------------------------------------------------------------------------
FROM node:20-alpine AS runner

WORKDIR /app

# Production environment — enables Next.js production optimizations
ENV NODE_ENV=production

# Disable Next.js anonymous usage telemetry at runtime
ENV NEXT_TELEMETRY_DISABLED=1

# Create a dedicated non-root user and group for running the application.
# Using fixed UID/GID (1001) ensures consistent file ownership across builds
# and avoids running the web server as root in production.
RUN addgroup --system --gid 1001 nodejs \
    && adduser --system --uid 1001 nextjs

# F-CRITICAL-1: Copy the filesystem-root @blitzy packages from the builder
# stage. Next.js standalone output bundles SSR code that may reference
# @blitzy/auth, so the package directory + pnpm store must remain reachable.
# Note: Next.js standalone output usually inlines required modules into
# .next/standalone/node_modules/, so this is precautionary for any code paths
# that resolve dynamically.
COPY --from=builder --chown=nextjs:nodejs /node_modules /node_modules
COPY --from=builder --chown=nextjs:nodejs /packages     /packages

# Copy the standalone build output from the builder stage.
# The standalone output includes a complete node_modules tree with only the
# production dependencies needed at runtime — significantly smaller than the
# full node_modules from the build stage.
# In a monorepo, the standalone output preserves the directory structure,
# so server.js is located at apps/web/server.js relative to the project root.
COPY --from=builder --chown=nextjs:nodejs /app/apps/web/.next/standalone ./

# Copy static assets that Next.js serves directly.
# These are NOT included in the standalone output and must be explicitly copied.
# Static files include compiled CSS, JS chunks, and other hashed assets.
COPY --from=builder --chown=nextjs:nodejs /app/apps/web/.next/static ./apps/web/.next/static

# Copy public directory (favicons, robots.txt, static images).
# The public/ directory contains files served at the root URL path.
# The builder stage ensures this directory exists via mkdir -p, so COPY
# will always succeed even if the directory is empty in early development.
COPY --from=builder --chown=nextjs:nodejs /app/apps/web/public ./apps/web/public

# Switch to non-root user for all subsequent commands and runtime execution
USER nextjs

# Expose the Next.js server port (default 3000)
EXPOSE 3000

# Set the port environment variable consumed by Next.js standalone server.
# The standalone server.js reads PORT from env to determine listen port.
ENV PORT=3000

# Set hostname to 0.0.0.0 to accept connections from outside the container.
# By default, Next.js standalone server listens on 0.0.0.0, but setting this
# explicitly ensures correct behavior across all deployment environments.
ENV HOSTNAME="0.0.0.0"

# Health check to verify the Next.js server is responsive.
# Uses wget (available in Alpine) instead of curl to avoid additional packages.
# Checks every 30 seconds, allows 5 seconds for response, retries 3 times
# before marking the container as unhealthy, with a 10-second startup grace.
HEALTHCHECK --interval=30s --timeout=5s --start-period=10s --retries=3 \
    CMD wget --no-verbose --tries=1 --spider http://localhost:3000/ || exit 1

# Start the Next.js standalone server.
# In production, this runs the self-contained server.js generated by `next build`
# with output: 'standalone'. In development (via docker-compose override), this
# CMD is replaced with `npm run dev --workspace=apps/web` for hot module reload.
CMD ["node", "apps/web/server.js"]
